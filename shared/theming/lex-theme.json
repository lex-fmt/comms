{
  "_comment": "Lex Monochrome theme — canonical data. Edited by humans; consumed by per-editor generators in vscode/, nvim/, lexed/, zed-lex/. Do not hand-edit generated files in those repos. See README.md (sibling of this file) for the schema.",
  "version": 1,
  "intensities": {
    "normal":   { "light": "#000000", "dark": "#e0e0e0" },
    "muted":    { "light": "#808080", "dark": "#888888" },
    "faint":    { "light": "#b3b3b3", "dark": "#666666" },
    "faintest": { "light": "#cacaca", "dark": "#555555" }
  },
  "backgrounds": {
    "code_bg":  { "light": "#f5f5f5", "dark": "#2a2a2a" }
  },
  "tokens": {
    "DocumentTitle":               { "intensity": "normal",   "styles": ["bold", "underline"] },
    "DocumentSubtitle":            { "intensity": "normal",   "styles": ["italic"] },
    "SessionTitleText":            { "intensity": "normal",   "styles": ["bold"] },
    "SessionMarker":               { "intensity": "muted",    "styles": ["italic"] },
    "DefinitionSubject":           { "intensity": "normal",   "styles": ["italic"] },
    "DefinitionContent":           { "intensity": "normal" },
    "ListMarker":                  { "intensity": "muted",    "styles": ["italic"] },
    "ListItemText":                { "intensity": "normal" },
    "InlineStrong":                { "intensity": "normal",   "styles": ["bold"] },
    "InlineEmphasis":              { "intensity": "normal",   "styles": ["italic"] },
    "InlineCode":                  { "intensity": "normal" },
    "InlineMath":                  { "intensity": "normal",   "styles": ["italic"] },
    "Reference":                   { "intensity": "muted",    "styles": ["bold"] },
    "ReferenceCitation":           { "intensity": "muted",    "styles": ["bold"] },
    "ReferenceFootnote":           { "intensity": "muted",    "styles": ["bold"] },
    "ReferenceAnnotation":         { "intensity": "muted",    "styles": ["bold"] },
    "AnnotationLabel":             { "intensity": "faint" },
    "AnnotationParameter":         { "intensity": "faint" },
    "AnnotationContent":           { "intensity": "faint" },
    "VerbatimSubject":             { "intensity": "faint" },
    "VerbatimLanguage":            { "intensity": "faint" },
    "VerbatimAttribute":           { "intensity": "faint" },
    "VerbatimContent":             { "intensity": "normal",   "background": "code_bg" },
    "InlineMarker_strong_start":   { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_strong_end":     { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_emphasis_start": { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_emphasis_end":   { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_code_start":     { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_code_end":       { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_math_start":     { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_math_end":       { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_ref_start":      { "intensity": "faintest", "styles": ["italic"] },
    "InlineMarker_ref_end":        { "intensity": "faintest", "styles": ["italic"] }
  }
}
