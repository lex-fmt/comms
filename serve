#!/usr/bin/env bash
set -euo pipefail

# Local docs preview. Serves the MkDocs site with live reload. The
# mkdocs-lex plugin re-renders .lex sources on edit. Requires the docs
# deps: pip install -r docs/requirements.txt (ideally in a venv).

PORT=8000

while [[ $# -gt 0 ]]; do
    case $1 in
        --port)
            PORT="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

cd "$(dirname "$0")"

if ! command -v mkdocs >/dev/null 2>&1; then
    echo "mkdocs not found. Install with: pip install -r docs/requirements.txt" >&2
    exit 1
fi

exec mkdocs serve --dev-addr "localhost:${PORT}"
